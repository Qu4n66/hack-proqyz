# Base URL of the ProQyz app (no trailing slash).
# Example: https://app.proqyz.com  or  https://staging.proqyz.com
PROQYZ_BASE_URL=https://app.proqyz.com

# Path to a directory where the persistent Chromium profile lives.
# This profile holds your logged-in session between runs.
# Default: ~/.proqyz-automation/profile
PROQYZ_PROFILE_DIR=

# Optional: storageState path (overrides PROQYZ_PROFILE_DIR for the cookies file).
# Default: ./storageState.json
PROQYZ_STORAGE_STATE=./storageState.json

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
